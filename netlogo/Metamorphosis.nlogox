<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.4" snapToGrid="true">
  <code><![CDATA[extensions [nw]

__includes [
  "setup_topology.nls"
  "network_metrics.nls"
  "reversible_dynamics.nls"
  "irreversible_dynamics.nls"
  "absorption_engine.nls"
  "scheduler_stop.nls"
  "viz_output.nls"
]

breed [cells cell]
breed [graph-agents graph-agent]
undirected-link-breed [cell-links cell-link]

globals [
  tick-counter
  model-ready?
  run-complete?

  external-temperature
  background-noise-level
  initial-energy-per-cell

  show-tissue-links
  show-imaginal-links
  show-organizer-links
  show-debris-links

  n-imaginal
  n-organizer
  n-debris
  imaginal-count-ratio
  organizer-count-ratio
  debris-count-ratio

  prop-tissue
  prop-imaginal
  prop-organizer
  prop-debris

  initial-tissue-cells
  initial-imaginal-cells
  initial-organizer-cells
  initial-debris-cells

  initial-occupied-cells
  initial-link-count

  target-tissue-absorbed-cells
  absorbed-tissue-cells
  tissue-dissolve-rate
  organizer-conversion-fraction
  target-organizer-converted-cells
  organizer-converted-cells
  total-cells-present
  total-links-present
  leftover-tissue-cells

  total-occupied-cells
  link-density
  global-graph-entropy
  tissue-entropy-total
  imaginal-entropy-total
  organizer-entropy-total
  debris-entropy-total

  background-heat-this-tick
  landauer-heat-this-tick
  landauer-heat-total
  ;cumulative-total-heat
  heat-ratio
  signed-cell-diff-total

  previous-total-occupied-cells
  previous-link-density
  previous-global-graph-entropy
  previous-heat-ratio

  structural-stable?
  irreversible-stable?
  heat-stable?
  absorption-target-reached?
  tissue-restabilized?
  irreversible-events-this-tick

  stabilization-window
  stabilization-counter
  max-ticks
]

patches-own [
  occupied?
]

cells-own [
  agent-id
  origin-agent-id
  agent-kind
  cell-type
  local-state
  noise-level
  energy-budget
  stress
  patterning-score
  commitment-bias
  regime-tag
  absorbable?
  prunable?
  pending-delete?
  node-erasure-flag
]

cell-links-own [
  link-type
  link-strength
  erasure-flag
  reversible-op?
  irreversible-op?
  link-pending-delete?
]

graph-agents-own [
  agent-id
  agent-kind
  regime-tag
  target-initial-cells
  initial-cell-count
  graph-size
  graph-entropy
  erased-links-count
  erased-nodes-count
  landauer-heat
  background-heat
  pruning-level
  commitment-score
  organizer-activity
  cleanup-score
  cohesion-score
  fragility-score
  absorbability-score
]

to setup
  clear-all
  reset-ticks 

  sync-legacy-interface-toggles
  setup-globals
  validate-setup
  setup-patches
  derive-agent-counts-from-tissue
  setup-graph-agents
  assign-initial-agent-sizes
  seed-all-agent-clusters
  build-initial-network-topologies
  update-link-visibility
  bootstrap-graph-agent-metrics ; from"network_metrics.nls"
  initialize-stabilization-memory ; from "network_metrics.nls"
  initialize-plots ; from viz-output.nls

  set model-ready? true
  set run-complete? false
end

to-report run-should-stop?
  report ticks > 0 and
         (absorbed-tissue-cells >= target-tissue-absorbed-cells) and
         structural-stable? and
         irreversible-stable? and
         heat-stable?
end

to go
  if not model-ready? [
    user-message "Run setup first."
    stop
  ]

  if run-should-stop? [
    set run-complete? true
    stop
  ]

  set irreversible-events-this-tick 0
  set landauer-heat-this-tick 0

  stage-environment ; scheduler_stop.nls
  stage-measure-pre ; network-metrics
  stage-rewire-reversible ; 	reversible_dynamics
  stage-measure-mid ; network-metrics
  stage-prune-irreversible ; irreversible_dynamics
  stage-absorb  ; absorption_engine
  if (absorbed-tissue-cells >= target-tissue-absorbed-cells) and (not tissue-restabilized?) [
    stabilize-remaining-tissue
  ]
  stabilize-organizer
  stabilize-imaginal
  stabilize-debris
  stage-organizer-and-debris ; irreversible_dynamics
  stage-bookkeeping  ; network-metrics
  stage-visualization ; viz-output

  tick
  set tick-counter ticks
end

to reset
  clear-all
  reset-ticks
  set model-ready? false
  set run-complete? false
end]]></code>
