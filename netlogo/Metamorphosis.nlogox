    <switch x="125" y="175" height="40" on="true" variable="l-imaginal" width="86" display="l-imaginal"></switch>
    <button x="75" y="270" height="40" disableUntilTicks="false" forever="true" kind="Observer" width="55" display="go">go</button>
    <slider x="15" step="0.05" y="115" max="0.75" width="155" display="tissue-absorbed" height="50" min="0.25" direction="Horizontal" default="0.75" variable="tissue-absorbed"></slider>
    <slider x="15" step="0.1" y="60" max="1" width="155" display="noise" height="50" min="0" direction="Horizontal" default="1.0" variable="noise" units="1 = 37° C"></slider>
    <slider x="180" step="0.005" y="115" max="0.05" width="150" display="absorption-rate" height="50" min="0.0005" direction="Horizontal" default="5.0E-4" variable="absorption-rate"></slider>
    <slider x="175" step="0.1" y="60" max="1" width="155" display="cells-energy" height="50" min="0" direction="Horizontal" default="1.0" variable="cells-energy"></slider>
    <slider x="15" step="10" y="5" max="1000" width="190" display="initial-total-occupied-cells" height="50" min="40" direction="Horizontal" default="800.0" variable="initial-total-occupied-cells"></slider>
    <slider x="213" step="1" y="5" max="8" width="150" display="n-tissue" height="50" min="1" direction="Horizontal" default="6.0" variable="n-tissue"></slider>
    <monitor x="1065" precision="0" y="5" height="60" fontSize="11" width="100" display="Tissue cells">leftover-tissue-cells</monitor>
    <monitor x="955" precision="17" y="5" height="60" fontSize="11" width="100" display="Links">total-links-present</monitor>
    <monitor x="845" precision="17" y="5" height="60" fontSize="11" width="100" display="Cells">total-cells-present</monitor>
    <plot x="845" autoPlotX="true" yMax="1.0E-21" autoPlotY="true" yAxis="heat (Joule)" y="75" xMin="0.0" height="175" legend="false" xMax="10.0" yMin="0.0" width="230" xAxis="ticks" display="Background Heat">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="background" color="-6459832" legend="true">
        <setup></setup>
        <update></update>
      </pen>
    </plot>
    <plot x="1080" autoPlotX="true" yMax="10.0" autoPlotY="true" yAxis="E per cell type" y="75" xMin="0.0" height="175" legend="true" xMax="10.0" yMin="0.0" xAxis="ticks" display="Entropy" width="280" sizeVersion="0">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="global" color="-16777216" legend="true">
        <setup></setup>
        <update></update>
      </pen>
      <pen interval="1.0" mode="0" display="tissue" color="-13840069" legend="true">
        <setup></setup>
        <update></update>
      </pen>
      <pen interval="1.0" mode="0" display="imaginal" color="-13791810" legend="false">
        <setup></setup>
        <update></update>
      </pen>
      <pen interval="1.0" mode="0" display="organizer" color="-2674135" legend="false">
        <setup></setup>
        <update></update>
      </pen>
      <pen interval="1.0" mode="0" display="debris" color="-7500403" legend="false">
        <setup></setup>
        <update></update>
      </pen>
    </plot>
    <button x="15" y="270" height="40" disableUntilTicks="false" forever="false" kind="Observer" width="55" display="setup">setup</button>
    <plot x="845" autoPlotX="true" yMax="1.0E-21" autoPlotY="true" yAxis="heat (Joule)" y="255" xMin="0.0" height="205" legend="false" xMax="10.0" yMin="0.0" width="230" xAxis="ticks" display="Landau Heat">
      <setup></setup>
      <update></update>
      <pen interval="1.0" mode="0" display="erasure" color="-2674135" legend="true">
        <setup></setup>
        <update></update>
      </pen>
    </plot>
    <plot x="1080" autoPlotX="true" yMax="1.0E-21" autoPlotY="true" yAxis="heat (joule/cell)" y="255" xMin="0.0" height="205" legend="true" xMax="10.0" yMin="0.0" width="280" xAxis="ticks" display="Landau Heat per cell">
      <setup></setup>
